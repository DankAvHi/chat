{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug client",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm run dev",
            "serverReadyAction": {
                "pattern": "http://localhost:.*m([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "killOnServerStop": true,
                "action": "debugWithChrome"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}
