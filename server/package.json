{
    "name": "server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "db-generate": "dotenv -e .env npx prisma generate",
        "db-generate:dev": "dotenv -e .env.development npx prisma generate",
        "db-pull:dev": "dotenv -e .env.development -- prisma db pull --force",
        "db-sync:dev": "pnpm run db-pull:dev && pnpm run db-generate:dev",
        "start:dev": "dotenv -e .env.development nodemon src/index.ts",
        "start": "dotenv -e .env pnpm run build && dotenv -e .env node build/index.bundle.js",
        "build": "node build.mjs",
        "format": "prettier --write \"./**/*.(ts|tsx|json)\"",
        "lint": "eslint \"./**/*.tsx\" \"./**/*.ts\"",
        "lint:fix": "eslint \"./**/*.tsx\" \"./**/*.ts\" --fix"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^4.12.0",
        "@trpc/server": "^10.20.0",
        "bcryptjs": "^2.4.3",
        "cli-color": "^2.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "dotenv-cli": "^7.2.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.0",
        "redis": "^4.6.5",
        "zod": "^3.21.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/cli-color": "^2.0.2",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.1",
        "@types/node": "^18.15.11",
        "@typescript-eslint/eslint-plugin": "^5.58.0",
        "esbuild": "0.17.16",
        "eslint": "^8.38.0",
        "nodemon": "^2.0.22",
        "prettier": "^2.8.7",
        "prisma": "^4.13.0",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.4"
    }
}
