{
    "version": "0.2.0",
    "configurations": [
        {
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "name": "Debug Server",
            "program": "${workspaceFolder}/server/src/index.ts",
            "request": "launch",
            "restart": true,
            "runtimeExecutable": "nodemon",
            "envFile": "${workspaceFolder}/server/.env.development",
            "skipFiles": ["<node_internals>/**"],
            "type": "node"
        },
        {
            "name": "Debug Client",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm run dev",
            "serverReadyAction": {
                "pattern": "http://localhost:.*m([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "killOnServerStop": true,
                "action": "debugWithChrome",
                "webRoot": "${workspaceFolder}/chat-client"
            },
            "cwd": "${workspaceFolder}/chat-client"
        }
    ],
    "compounds": [
        {
            "name": "Debug Whole App",
            "configurations": ["Debug Client", "Debug Server"]
        }
    ]
}
